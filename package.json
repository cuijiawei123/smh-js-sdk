{
  "name": "smh-js-sdk",
  "version": "1.0.0",
  "description": "腾讯云智能媒资托管服务 JavaScript/TypeScript SDK",
  "keywords": [
    "tencent",
    "tencent cloud",
    "qcloud",
    "smh",
    "smh-sdk",
    "openapi"
  ],
  "author": "juanjualong",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/smh-sdk.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run build:browser",
    "build:browser": "esbuild index.ts --bundle --format=esm --outfile=dist/smh-sdk.esm.js --platform=browser --target=es2020 --external:fs --external:path --external:crypto",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "npm run test:integration",
    "test:watch": "npm run test:integration:watch",
    "test:integration": "dotenv -e .env -- vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "dotenv -e .env -- vitest --config vitest.integration.config.ts",
    "test:integration:coverage": "dotenv -e .env -- vitest run --config vitest.integration.config.ts --coverage",
  },
  "dependencies": {
    "axios": "^1.6.1",
    "hash-wasm": "^4.11.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^8.0.0",
    "esbuild": "^0.27.2",
    "typescript": "^4.0 || ^5.0",
    "vitest": "^4.0.18"
  }
}
