# SMH JS SDK 集成测试配置
# 复制本文件为 .env 并填入真实值
#
# ⚠️ 注意：.env 文件包含密钥等敏感信息，严禁提交到 Git 仓库！
# 请确认 .gitignore 中已包含 .env，切勿将真实配置提交到远程仓库。

# SMH API 基础路径
SMH_BASE_PATH=https://api.tencentsmh.cn

# Library ID
SMH_LIBRARY_ID=your_library_id

# Space ID
SMH_SPACE_ID=your_space_id

# 媒体库密钥（在腾讯云控制台创建媒体库后获取）
SMH_LIBRARY_SECRET=your_library_secret

# 用户 ID（用于签发测试 token）
SMH_USER_ID=your_user_id

# 可选：签发 token 权限（默认 admin）
# SMH_TOKEN_GRANT=admin

# 可选：签发 token 有效期秒数（默认 3600）
# SMH_TOKEN_PERIOD=3600

# 可选：是否开启空间写操作测试（创建/删除空间，需额外权限）
# 1 = 开启，其他值或不填 = 跳过
# SMH_ENABLE_SPACE_WRITE_TESTS=0
